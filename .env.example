# Server ports
BFF_PORT=3001
GATE_PORT=3002
NOTIFY_PORT=3003
PORT=3000
APP_URL=http://localhost:3001

# Admin credentials (change in production!)
ADMIN_PASSWORD=Change_Me_123!
ADMIN_EMAIL=admin@example.com
ADMIN_PHONE=+48000000000

# Environment
MODE=dev
DEV_MODE=false

# CORS & Client
ALLOWED_ORIGIN=http://localhost:4002
CLIENT_URL=http://localhost:4002

# Cookie & Session config
COOKIE_SECRET=your-cookie-secret-here-min-64-chars-recommended
SESSION_SECRET=your-session-secret-here-min-64-chars-recommended
SESSION_NAME=session_auth
SESSION_DOMAIN=localhost
SESSION_MAX_AGE=86400000
SESSION_HTTP_ONLY=true
SESSION_SECURE=false
SESSION_FOLDER=sessions_dev
SESSION_SAME_SITE=lax

# Database
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres_password_here
DATABASE_PORT=5432
DATABASE_DB=db_auth
DATABASE_SYNC=true
DATABASE_HOST=postgres

# Redis
REDIS_PORT=6379
REDIS_PASSWORD=redis_password_here
REDIS_HOST=redis
REDIS_QUEUE_MAX=500

# Database connection pool
POSTGRES_POOL_MIN=2
POSTGRES_POOL_MAX=10

# gRPC Services URLs
DB_GRPC_URL=grpc://db-service:50051
GATE_GRPC_URL=grpc://core-service:50053
NOTIFY_GRPC_URL=grpc://notify-service:50052

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=noreply@example.com

# SMS/Messaging
TWILO_SID=your_twilio_sid
TWILO_TOKEN=your_twilio_token
TWILO_PHONE=+1234567890

# Signal bridge
SIGNAL_API_URL=http://signal-api:8080

# LLM API Keys
GROQ_API_KEY=your-groq-api-key
OPENAI_API_KEY=your-openai-api-key

# Third-party credentials
POSTMAN_API_KEY=your-postman-api-key

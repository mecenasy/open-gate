{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "watchAssets": true,
    "assets": [
      {
        "include": "**/*.proto",
        "watchAssets": true
      }
    ]
  },
  "watchOptions": {
    "usePolling": true,
    "interval": 1000
  },
  "monorepo": true,
  "projects": {
    "api-gateway": {
      "type": "application",
      "root": "apps/api-gateway",
      "entryFile": "src/user-service/main",
      "sourceRoot": "src"
    },
    "grpc-service": {
      "type": "application",
      "root": "apps/grpc-service",
      "entryFile": "src/grpc-service/main",
      "sourceRoot": "src"
    }
  }
}
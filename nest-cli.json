{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "watchAssets": true,
    "assets": [
      {
        "include": "**/*.proto",
        "watchAssets": true
      }
    ],
    "webpack": true
  },
  "watchOptions": {
    "usePolling": true,
    "interval": 1000
  },
  "monorepo": true,
  "projects": {
    "db-grpc": {
      "type": "library",
      "root": "libs/db-grpc",
      "entryFile": "index",
      "sourceRoot": "libs/db-grpc/src",
      "compilerOptions": {
        "tsConfigPath": "libs/db-grpc/tsconfig.lib.json"
      }
    },
    "db-service": {
      "type": "application",
      "root": "apps/db-service",
      "entryFile": "src/db-service/main",
      "sourceRoot": "src"
    },
    "event": {
      "type": "library",
      "root": "libs/event",
      "entryFile": "index",
      "sourceRoot": "libs/event/src",
      "compilerOptions": {
        "tsConfigPath": "libs/event/tsconfig.lib.json"
      }
    },
    "gate-grpc": {
      "type": "library",
      "root": "libs/gate-grpc",
      "entryFile": "index",
      "sourceRoot": "libs/gate-grpc/src",
      "compilerOptions": {
        "tsConfigPath": "libs/gate-grpc/tsconfig.lib.json"
      }
    },
    "core-service": {
      "type": "application",
      "root": "apps/core-service",
      "entryFile": "src/core-service/main",
      "sourceRoot": "src"
    },
    "handler": {
      "type": "library",
      "root": "libs/handler",
      "entryFile": "index",
      "sourceRoot": "libs/handler/src",
      "compilerOptions": {
        "tsConfigPath": "libs/handler/tsconfig.lib.json"
      }
    },
    "notify-grpc": {
      "type": "library",
      "root": "libs/notify-grpc",
      "entryFile": "index",
      "sourceRoot": "libs/notify-grpc/src",
      "compilerOptions": {
        "tsConfigPath": "libs/notify-grpc/tsconfig.lib.json"
      }
    },
    "notify-service": {
      "type": "application",
      "root": "apps/notify-service",
      "entryFile": "src/notify-service/main",
      "sourceRoot": "src"
    },
    "redis": {
      "type": "library",
      "root": "libs/redis",
      "entryFile": "index",
      "sourceRoot": "libs/redis/src",
      "compilerOptions": {
        "tsConfigPath": "libs/redis/tsconfig.lib.json"
      }
    },
    "shared-redis": {
      "type": "library",
      "root": "libs/shared-redis",
      "entryFile": "index",
      "sourceRoot": "libs/shared-redis/src",
      "compilerOptions": {
        "tsConfigPath": "libs/shared-redis/tsconfig.lib.json"
      }
    },
    "tenant": {
      "type": "library",
      "root": "libs/tenant",
      "entryFile": "index",
      "sourceRoot": "libs/tenant/src",
      "compilerOptions": {
        "tsConfigPath": "libs/tenant/tsconfig.lib.json"
      }
    }
  }
}
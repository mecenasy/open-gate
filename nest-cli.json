{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "watchAssets": true,
    "assets": [
      {
        "include": "**/*.proto",
        "watchAssets": true
      }
    ]
  },
  "watchOptions": {
    "usePolling": true,
    "interval": 1000
  },
  "monorepo": true,
  "projects": {
    "gate-service": {
      "type": "application",
      "root": "apps/gate-service",
      "entryFile": "src/gate-service/main",
      "sourceRoot": "src"
    },
    "grpc-service": {
      "type": "application",
      "root": "apps/grpc-service",
      "entryFile": "src/grpc-service/main",
      "sourceRoot": "src"
    },
    "notify-service": {
      "type": "application",
      "root": "apps/notify-service",
      "entryFile": "src/notify-service/main",
      "sourceRoot": "src"
    }
  }
}
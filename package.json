{
  "name": "open-gate",
  "version": "0.0.2",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch --preserveWatchOutput",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "typeorm": "typeorm-ts-node-commonjs",
    "db:drop": "typeorm schema:drop -- -d typeorm.config.ts",
    "migration:create": "npm run typeorm migration:create",
    "migration:generate": "npm run build && npm run typeorm migration:generate -- -d typeorm.config.ts",
    "migration:revert": "npm run build && npm run typeorm migration:revert -- -d typeorm.config.ts",
    "migration:run": "npm run build && npm run typeorm migration:run -- -d typeorm.config.ts",
    "migration:run:prod": "typeorm migration:run -d ./dist/typeorm.config.js",
    "deploy": "npm install && npm run build && npm run migration:run:prod",
    "proto": "npx protoc --plugin=./node_modules/.bin/protoc-gen-ts_proto.cmd --ts_proto_out=./ --ts_proto_opt=nestJs=true,addGrpcMetadata=true,addReflection=false ./src/proto/*.proto"
  },
  "dependencies": {
    "@apollo/server": "^5.4.0",
    "@as-integrations/express5": "^1.1.2",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@grpc/reflection": "^1.0.4",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/apollo": "^13.2.4",
    "@nestjs/axios": "^4.0.1",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.0.1",
    "@nestjs/cqrs": "^11.0.3",
    "@nestjs/graphql": "^13.2.4",

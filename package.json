    "passport": "^0.7.0",
    "passport-azure-ad": "^4.3.5",
    "passport-facebook": "^3.0.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "passport-linkedin-oauth2": "^2.0.0",
    "passport-twitter": "^1.0.4",
    "pg": "^8.18.0",
    "qrcode": "^1.5.4",

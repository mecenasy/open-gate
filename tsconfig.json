{
  "exclude": [
    "node_modules",
    "test",
    "dist",
    "**/*spec.ts",
    "./src/front-service"
  ],
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "resolvePackageJsonExports": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "strictPropertyInitialization": false,
    "allowSyntheticDefaultImports": true,
    "target": "ES2023",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "forceConsistentCasingInFileNames": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "noFallthroughCasesInSwitch": false,
    "paths": {
      "@app/db-grpc": [
        "src/libs/db-grpc/src"
      ],
      "@app/db-grpc/*": [
        "src/libs/db-grpc/src/*"
      ],
      "@app/event": [
        "src/libs/event/src"
      ],
      "@app/event/*": [
        "src/libs/event/src/*"
      ],
      "@app/gate-grpc": [
        "src/libs/gate-grpc/src"
      ],
      "@app/gate-grpc/*": [
        "src/libs/gate-grpc/src/*"
      ],
      "@app/handler": [
        "src/libs/handler/src"
      ],
      "@app/handler/*": [
        "src/libs/handler/src/*"
      ],
      "@app/notify-grpc": [
        "src/libs/notify-grpc/src"
      ],
      "@app/notify-grpc/*": [
        "src/libs/notify-grpc/src/*"
      ],
      "@app/redis": [
        "src/libs/redis/src"
      ],
      "@app/redis/*": [
        "src/libs/redis/src/*"
      ],
      "@app/auth": [
        "src/libs/auth/src"
      ],
      "@app/auth/*": [
        "src/libs/auth/src/*"
      ],
      "@app/config": [
        "src/libs/config/src"
      ],
      "@app/config/*": [
        "src/libs/config/src/*"
      ],
      "@app/logger": [
        "src/libs/logger"
      ],
      "@app/logger/*": [
        "src/libs/logger/*"
      ],
      "@app/tenant": [
        "src/libs/tenant/src"
      ],
      "@app/tenant/*": [
        "src/libs/tenant/src/*"
      ],
      "@app/cqrs": [
        "src/libs/cqrs/src"
      ],
      "@app/cqrs/*": [
        "src/libs/cqrs/src/*"
      ],
      "@app/database": [
        "src/libs/database/src"
      ],
      "@app/database/*": [
        "src/libs/database/src/*"
      ],
      "@app/customization": [
        "src/libs/customization/src"
      ],
      "@app/customization/*": [
        "src/libs/customization/src/*"
      ],
      "@app/entities": [
        "src/libs/entities/src"
      ],
      "@app/entities/*": [
        "src/libs/entities/src/*"
      ],
      "@app/dto": [
        "src/libs/dto/src"
      ],
      "@app/dto/*": [
        "src/libs/dto/src/*"
      ],
      "@app/quotas": [
        "src/libs/quotas/src"
      ],
      "@app/quotas/*": [
        "src/libs/quotas/src/*"
      ],
      "@app/audit": [
        "src/libs/audit/src"
      ],
      "@app/audit/*": [
        "src/libs/audit/src/*"
      ],
      "@app/billing": [
        "src/libs/billing/src"
      ],
      "@app/billing/*": [
        "src/libs/billing/src/*"
      ],
      "src/*": [
        "src/*"
      ]
    }
  },
  "watchOptions": {
    "watchFile": "fixedPollingInterval",
    "watchDirectory": "fixedPollingInterval",
    "fallbackPolling": "fixedInterval",
    "synchronousWatchDirectory": true,
    "excludeDirectories": [
      "**/node_modules",
      "dist"
    ]
  }
}